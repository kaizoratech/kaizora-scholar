PORT=3001
NODE_ENV=development

# AES-256-GCM Key — MUST be exactly 32 UTF-8 characters (256-bit)
APP_KEY=your_32_character_secret_key_here

# Supabase Transaction Pooler URI
DATABASE_URL=postgresql://user:password@host:6543/dbname

# Google Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here

# CORS — set to frontend origin in production
FRONTEND_URL=http://localhost:5173
